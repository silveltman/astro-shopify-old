---
import Layout from '@layouts/Base.astro'
import Hero from '@components/macro/Hero.svelte'
import Cta from '@components/macro/Cta.svelte'
import Collections from '@components/macro/Carousel.svelte'
const { seo, hero } = Astro.props.frontmatter

import { getCollections, getProducts } from 'public/shopify'
import Header from '@components/macro/Header.svelte'

let collections = await getCollections()
let products = await getProducts()
---

<Layout {seo}>
  <!-- <HeroBoxed content={hero} /> -->
  <!-- <Carousel /> -->

  <Header client:load />
  <Hero />

  <Collections
    items={collections}
    client:load
  />

  <Cta />
</Layout>
